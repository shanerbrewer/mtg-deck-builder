# Anthropic — get your key at https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# Auth.js — generate a random secret with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth App — create at https://github.com/settings/developers
# Homepage URL:   https://<your-project>.vercel.app
# Callback URL:   https://<your-project>.vercel.app/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Vercel KV (Upstash Redis) — connect via Vercel dashboard → Storage → Upstash for Redis
# These env vars are auto-injected when you connect the integration to your project.
KV_REST_API_URL=
KV_REST_API_TOKEN=
